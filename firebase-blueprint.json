{
  "entities": {
    "Photo": {
      "title": "Photo",
      "description": "Metadata for an uploaded image",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the photo" },
        "description": { "type": "string", "description": "Short description or caption" },
        "url": { "type": "string", "description": "The public storage URL of the image" },
        "storagePath": { "type": "string", "description": "Internal storage path for deletion" },
        "albumId": { "type": "string", "description": "Reference to the album it belongs to" },
        "userId": { "type": "string", "description": "Owner identifier" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" }
      },
      "required": ["title", "url", "storagePath", "userId", "createdAt"]
    },
    "Album": {
      "title": "Album",
      "description": "A collection of photos",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the album" },
        "description": { "type": "string", "description": "Short description of the album content" },
        "userId": { "type": "string", "description": "Owner identifier" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Collection of photo metadata"
    },
    "/albums/{albumId}": {
      "schema": "Album",
      "description": "Collection of gallery albums"
    }
  }
}
